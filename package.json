{
  "name": "@revolutionarygamesco/common",
  "description": "A library of methods that we tend to use in all (or at least most) of our projects.",
  "version": "1.0.0",
  "homepage": "https://github.com/revolutionarygamesco/common",
  "bugs": "https://github.com/revolutionarygamesco/common/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revolutionarygamesco/common.git"
  },
  "license": "GPL-3.0-or-later",
  "contributors": [
    {
      "name": "Jason Godesky",
      "email": "jason@revolutionarygames.co"
    }
  ],
  "funding": {
    "type": "patreon",
    "url": "https://patreon.com/revolutionarygamesco"
  },
  "type": "module",
  "files": ["dist", "src", "!src/**/*.test.ts", "!src/**/*.test-d.ts"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.21",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
